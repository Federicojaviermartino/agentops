# ============================================================
# AgentOps - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Database (Required) ---
DATABASE_URL="postgresql://agentops:agentops2026@localhost:5432/agentops?schema=public"

# --- JWT Auth (Required - auto-generated on Render) ---
JWT_SECRET="change-this-to-random-64-chars"
JWT_REFRESH_SECRET="change-this-to-another-random-64-chars"

# --- AI Provider (Required for assessments) ---
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-20250514"
# Fallback
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"

# --- Stripe Billing (Required for paid plans) ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# --- Email via Resend (Optional) ---
RESEND_API_KEY=""
EMAIL_FROM="AgentOps <noreply@agentops.eu>"

# --- S3 Document Storage (Optional - uses local if not set) ---
S3_ENDPOINT=""
S3_BUCKET="agentops-documents"
AWS_REGION="eu-west-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# --- Bias Detection Microservice (Optional) ---
BIAS_SERVICE_URL="http://localhost:8000"

# --- Application ---
NODE_ENV="development"
PORT=3000
FRONTEND_URL="http://localhost:4200"
APP_VERSION="1.0.0"
ENABLE_DOCS="true"
ENABLE_MONITORING="false"

# --- Render (auto-set by Render) ---
# RENDER_EXTERNAL_HOSTNAME=agentops-api.onrender.com
